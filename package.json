{
  "name": "thermo-logger",
  "version": "1.1.0",
  "description": "Raspberry Pi based temperature logger",
  "main": "index.js",
  "scripts": {
    "dev": "npx tsx --watch src/main.ts",
    "dev_sim": "npx tsx --watch src/main.ts --config config/sim_config.json",
    "build": "prisma generate && tsc",
    "db:init": "prisma migrate dev --name init",
    "db:migrate": "prisma migrate dev",
    "web:install": "cd web/ && npm install",
    "web:build": "cd web/ && npm run build",
    "start": "node dist/main.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@types/better-sqlite3": "^7.6.13",
    "cors": "^2.8.6",
    "ds18b20": "^0.1.0",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "prisma": "^7.4.0",
    "ws": "^8.19.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/ds18b20": "^0.1.3",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "@types/ws": "^8.18.1",
    "@types/yargs": "^17.0.35",
    "typescript": "^5.9.3"
  }
}
