generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Sensor {
  id             Int             @id @default(autoincrement())
  hardwareId     String          @unique // 1-wire unique ID
  createdAt      DateTime        @default(now())
  isSimulated    Boolean
  currentName    String

  sessionSensors SessionSensor[]
  samples        Sample[]
}

model SessionSensor {
  id        Int    @id @default(autoincrement())
  sessionId Int
  sensorId  Int
  name      String // snapshot name for THIS session

  session RecordSession @relation(fields: [sessionId], references: [id])
  sensor  Sensor        @relation(fields: [sensorId], references: [id])

  @@unique([sessionId, sensorId])
}

model RecordSession {
  id             Int       @id @default(autoincrement())
  name           String
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  sampleRateMs   Int
  notes          String    @default("")
  lastExportedAt DateTime?
  exportPath     String? // filepath of exported data

  samples        Sample[]
  sessionSensors SessionSensor[]
}

model SampleGroup {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  sessionId Int
  
  samples   Sample[]

  @@index([sessionId])
}

model Sample {
  id            Int   @id @default(autoincrement())
  tempC         Float
  sensorId      Int
  sessionId     Int
  sampleGroupId Int

  sensor      Sensor        @relation(fields: [sensorId], references: [id])
  session     RecordSession @relation(fields: [sessionId], references: [id])
  sampleGroup SampleGroup   @relation(fields: [sampleGroupId], references: [id])

  @@index([sensorId])
  @@index([sessionId])
  @@index([sampleGroupId])
}
